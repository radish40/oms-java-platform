# Copy to .env.deploy on the server. Do not commit real secrets.

SERVICE_NAME=oms-java-platform
GIT_BRANCH=main
PORT=18020
HEALTH_URL=http://127.0.0.1:18020/health
PROCESS_PATTERN=oms-java-platform

SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC
MAVEN_ARGS=-DskipTests -B
MAVEN_SETTINGS=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=oms_db
DB_USER=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

PLATFORM_AUTH_SECRET=
PLATFORM_DEFAULT_USER=admin
PLATFORM_DEFAULT_PASSWORD=
PLATFORM_DEFAULT_DISPLAY=Platform Admin
PLATFORM_SUPPORT_USER=support
PLATFORM_SUPPORT_PASSWORD=
PLATFORM_SUPPORT_DISPLAY=Platform Support

MODEL_RUNTIME_URL=http://127.0.0.1:18010
